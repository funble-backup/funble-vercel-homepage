# Database (omit both for local funble.db)
# TURSO_DATABASE_URL=libsql://...
# TURSO_DATABASE_TOKEN=

# Public base URL for announcement PDFs on Cloudflare R2 (or any CDN).
# Must match how objects are exposed (R2.dev subdomain or custom domain).
# Used to skip re-mirroring in admin save and to detect already-migrated rows in scripts.
# R2_PUBLIC_BASE_URL=https://pub-xxxxxxxxxxxx.r2.dev

# Optional alias (if set, either prefix is accepted for CDN detection)
# ANNOUNCEMENTS_ASSET_BASE_URL=https://cdn.example.com

# Optional extra hostnames (comma-separated) treated as CDN, e.g. custom domain without env prefix
# ANNOUNCEMENTS_ASSET_HOSTS=cdn.example.com,files.example.com

# R2 S3-compatible API (for migrate-announcement-pdfs-to-r2 script and optional uploads)
# R2_ACCOUNT_ID=your_cloudflare_account_id
# R2_ACCESS_KEY_ID=
# R2_SECRET_ACCESS_KEY=
# R2_BUCKET_NAME=funble-announcements
